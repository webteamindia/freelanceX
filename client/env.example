# Copy to .env.local for local development.

# Backend API (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:5001

# NextAuth (Google sign-in) — generate secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PayPal (public client id from PayPal developer dashboard)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# Optional: AI support chat (OpenRouter)
AGENT_API=

# Optional: Google AdSense — also update public/ads.txt with your publisher id
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_HOME_SLOT=
NEXT_PUBLIC_ADSENSE_SEARCH_SLOT=
