# Copy to .env and fill in values. Required keys are enforced on startup in production.

NODE_ENV=development
PORT=5001
BASE_PATH=/api

# MongoDB (Prisma)
DATABASE_URL=mongodb+srv://user:pass@cluster.example/freelancex

# Comma-separated frontend URL(s) for CORS and password-reset links
PUBLIC_URL=http://localhost:3000

# Use long random strings (32+ chars). Never use defaults in production.
JWT_SECRET=dev_jwt_secret_change_me_use_openssl_rand_hex_32
JWT_EXPIRES_IN=3d
JWT_REFRESH_SECRET=dev_jwt_refresh_change_me_use_openssl_rand_hex_32
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (gig & profile images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PayPal — use sandbox credentials until launch; set PAYPAL_MODE=live for production
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_BRAND_NAME=ffiver
# Platform fee taken from each order (seller receives the remainder)
PLATFORM_FEE_PERCENT=10
# Dev only: skip real PayPal Payouts API and mark orders as released
# PAYPAL_SIMULATE_PAYOUTS=true

# SMTP (forgot password, support notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
SUPPORT_EMAIL=support@example.com
